# YouTube API Key
# Get it from: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# SMTP Configuration (For sending application confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe API Credentials
# Get them from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Firebase Admin SDK (For server-side Firestore/Auth access)
# Generate it from: Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Paste the ENTIRE JSON content as a single line or string
FIREBASE_SERVICE_ACCOUNT_KEY=

# bKash API Credentials (Sandbox/Production)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_TOKEN=
